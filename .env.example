# PromptPerfect Environment Variables
# Copy to .env.local and fill in real values.

# Default LLM provider (Gemini) — get your key at https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# Optional — Gemini model id (default: gemini-2.5-flash). Change if Google deprecates a model or you hit quotas.
# GEMINI_MODEL=gemini-2.5-flash

# Supabase (auth, history, profiles, library)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional LLM providers (user-supplied keys; leave blank to disable those providers)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Required for correct OAuth + email-confirmation + password-reset redirects in production.
# No trailing slash. On Vercel, set this to your deployment URL (same value as Site URL in Supabase).
# Local dev: http://localhost:3000 (add these Redirect URLs in Supabase → Authentication → URL Configuration):
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset
# Production: https://<your-domain>/auth/callback and https://<your-domain>/auth/reset
#
# Google OAuth (fixes "Error getting user profile from external provider"):
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Web client
# 2. Authorized redirect URI (required): https://<project-ref>.supabase.co/auth/v1/callback
# 3. Supabase Dashboard → Authentication → Google: paste Client ID + Client Secret, enable provider
# 4. OAuth consent screen: add test users while app is in "Testing" mode
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Comma-separated origins allowed to call `/api/optimize-sync` from the browser (CORS).
ALLOWED_ORIGINS=http://localhost:3000,https://promptperfect-beaglecorp.vercel.app

# Optional — only needed for local Supabase migrations
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
